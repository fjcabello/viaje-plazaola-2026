  <metadata><name>Día 3 · Salvatierra-Agurain → Etxarri-Aranatz</name><desc>Viaje en bici Julio 2026 · Vía Verde del Plazaola</desc></metadata>
  <wpt lat="42.850200" lon="-2.388200">
    <ele>600.0</ele>
    <name>Km 0 · Partida</name>
    <desc>Salvatierra-Agurain. Salida hacia el este,&#10;cruzando la Llanada y luego hacia Navarra.</desc>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="42.860000" lon="-2.283000">
    <ele>599.9</ele>
    <name>Km 8 · Corredor de la Barranca</name>
    <desc>Zona de transición Álava/Navarra.&#10;El paisaje cambia: más húmedo, primeros pinos y hayas.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="42.876000" lon="-2.248000">
    <ele>557.3</ele>
    <name>Km 15 · Límite Álava / Navarra</name>
    <desc>Mojón de provincia. Foto obligatoria: dos comunidades, un pedalazo.&#10;A la derecha el perfil de la Sierra de Urbasa (~1.000 m).&#10;Parada: 5 min.</desc>
    <sym>Flag, Red</sym>
  </wpt>
  <wpt lat="42.900300" lon="-2.167900">
    <ele>524.4</ele>
    <name>Km 20 · Alsasua / Altsasu</name>
    <desc>Primera gran localidad navarra (~7.000 hab).&#10;Supermercado, farmacia, bares.&#10;★ ALMUERZO IDEAL a mitad de etapa.&#10;Parada: 30-40 min.</desc>
    <sym>Restaurant</sym>
  </wpt>
  <wpt lat="42.883300" lon="-2.101400">
    <ele>535.8</ele>
    <name>Km 27 · Olazagutia / Olazti</name>
    <desc>Pueblo navarro con iglesia y fuente.&#10;Al norte se ve la Sierra de Aralar con el santuario&#10;de San Miguel in Excelsis (s. XII).&#10;Parada: 5 min.</desc>
    <sym>Camera</sym>
  </wpt>
  <wpt lat="42.898700" lon="-2.069400">
    <ele>488.2</ele>
    <name>Km 34 · LLEGADA Etxarri-Aranatz</name>
    <desc>Hotel Aritzalko · Ctra. Pamplona-Vitoria Km 23&#10;Tel: 948 46 00 51&#10;Sirve desayunos, comida y cena con productos locales.</desc>
    <sym>Lodging</sym>
  </wpt>
  <trk>
