  xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
  <metadata><name>Día 2 · Vitoria → Salvatierra-Agurain</name><desc>Viaje en bici Julio 2026 · Vía Verde del Plazaola</desc></metadata>
  <wpt lat="42.858900" lon="-2.683100">
    <ele>524.3</ele>
    <name>Km 0 · Partida</name>
    <desc>Gamarra Mayor (Vitoria-Gasteiz)&#10;Seguir señalización ESTE por el Anillo Verde hacia la Llanada Alavesa.</desc>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="42.841500" lon="-2.634000">
    <ele>543.6</ele>
    <name>Km 4 · Argandoña (desvío opcional)</name>
    <desc>Pueblo medieval con torre de los Villela (s. XV). Desvío +1 km por camino de tierra.&#10;Solo si arrancáis con energía. Parada: 15 min.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="42.851200" lon="-2.538000">
    <ele>577.1</ele>
    <name>Km 11 · Apertura de la Llanada</name>
    <desc>La llanura cerealista se extiende a 360°.&#10;Vistas hacia la Sierra de Entzia al sur. Foto de grupo.&#10;Parada: 5 min.</desc>
    <sym>Camera</sym>
  </wpt>
  <wpt lat="42.854200" lon="-2.460000">
    <ele>675.0</ele>
    <name>Km 19 · Araya / Aspárrena</name>
    <desc>Primer bar con bocadillo (domingo: confirmar apertura).&#10;Fuente en la plaza municipal.&#10;Parada: 10 min.</desc>
    <sym>Restaurant</sym>
  </wpt>
  <wpt lat="42.850300" lon="-2.391400">
    <ele>600.0</ele>
    <name>Km 27 · Entrada a Salvatierra</name>
    <desc>La muralla medieval aparece en el horizonte.&#10;Entrar por la Puerta de Santa María.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="42.850200" lon="-2.388200">
    <ele>600.0</ele>
    <name>Km 28 · LLEGADA Salvatierra-Agurain</name>
    <desc>El Gordo · Calle Mayor 69&#10;Contacto: Montse 699 453 986&#10;Aparcar bicis y explorar el casco amurallado a pie. Parada: 30-45 min.</desc>
    <sym>Lodging</sym>
  </wpt>
  <trk>
