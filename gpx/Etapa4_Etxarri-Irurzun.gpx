<gpx version="1.1" creator="Pedaleando voy, pedaleando vengo 2026"
  xmlns="http://www.topografix.com/GPX/1/1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
  <metadata><name>Día 4 · Etxarri-Aranatz → Irurzun</name><desc>Viaje en bici Julio 2026 · Vía Verde del Plazaola</desc></metadata>
  <wpt lat="42.898700" lon="-2.069400">
    <ele>506.6</ele>
    <name>Km 0 · Partida</name>
    <desc>Etxarri-Aranatz.&#10;INICIO de la Vía Verde del Plazaola (tramo navarro).&#10;Primer cartel histórico del tren txiki.</desc>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="42.904200" lon="-1.998300">
    <ele>483.1</ele>
    <name>Km 5 · Arbizu</name>
    <desc>Primer pueblo en la Vía Verde.&#10;Hay bar y fuente en la plaza. El río Arakil aparece.&#10;Parada: 5 min.</desc>
    <sym>Restaurant</sym>
  </wpt>
  <wpt lat="42.912500" lon="-1.937200">
    <ele>472.3</ele>
    <name>Km 10 · Viaducto de Goldaratz</name>
    <desc>Puente de arco de piedra del antiguo ferrocarril sobre el río Araquil.&#10;Bajar las bicis y verlo desde abajo: impresionante.&#10;Parada: 10 min.</desc>
    <sym>Flag, Red</sym>
  </wpt>
  <wpt lat="42.918000" lon="-1.889200">
    <ele>447.0</ele>
    <name>Km 14 · Lacunza · Fuente</name>
    <desc>Caserío con fuente junto a la ermita.&#10;El trazado del viejo tren se nota: curvas suaves, pendiente mínima.&#10;Parada: 5 min.</desc>
    <sym>Drinking Water</sym>
  </wpt>
  <wpt lat="42.919500" lon="-1.851400">
    <ele>461.0</ele>
    <name>Km 18 · Irañeta · Mojón del Camino Real</name>
    <desc>Inscripción: "A Pamplona tres leguas"&#10;Resto del antiguo camino que unía Pamplona con San Sebastián.&#10;Parada: 5 min.</desc>
    <sym>Camera</sym>
  </wpt>
  <wpt lat="42.917800" lon="-1.828700">
    <ele>454.1</ele>
    <name>Km 22 · Túneles de Ihabar</name>
    <desc>Primeros túneles cortos de la Vía Verde (linterna útil).&#10;Paso calizo de Dos Hermanas junto al río.&#10;Tramo de especial belleza.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="42.912600" lon="-1.806100">
    <ele>454.1</ele>
    <name>Km 25 · LLEGADA Irurzun / Irurtzun</name>
    <desc>Hotel Plazaola ★★★ · C/ Aralar 8&#10;Tel: 948 50 63 13 · reservas@hotelplazaola.es&#10;Restaurante propio (consultar si el desayuno está incluido).</desc>
    <sym>Lodging</sym>
  </wpt>
  <trk>
    <name>Día 4 · Etxarri-Aranatz → Irurzun</name>
