  <metadata>
    <name>Viaje en bici Julio 2026 · Vía Verde del Plazaola</name>
    <desc>Vitoria-Gasteiz → San Sebastián · 5 etapas · ~158 km</desc>
  </metadata>
  <wpt lat="42.858900" lon="-2.683100">
    <ele>523.1</ele>
    <name>E1 · Km 0 · Partida</name>
    <desc>Gamarra Mayor (Vitoria-Gasteiz). Seguir señalización ESTE por el Anillo Verde.</desc>
  </wpt>
  <wpt lat="42.841500" lon="-2.634000">
    <ele>543.6</ele>
    <name>E1 · Km 4 · Argandoña (opcional)</name>
    <desc>Desvío +1 km. Pueblo medieval con torre de los Villela (s. XV). Opcional · 15 min.</desc>
  </wpt>
  <wpt lat="42.851200" lon="-2.538000">
    <ele>577.1</ele>
    <name>E1 · Km 11 · Apertura de la Llanada</name>
    <desc>Llanura cerealista a 360°. Vistas Sierra de Entzia al sur. Foto · 5 min.</desc>
  </wpt>
  <wpt lat="42.854200" lon="-2.460000">
    <ele>675.0</ele>
    <name>E1 · Km 19 · Araya · Bar</name>
    <desc>Primer bar con bocadillo (domingo: confirmar apertura). Fuente en la plaza. 10 min.</desc>
  </wpt>
  <wpt lat="42.850300" lon="-2.391400">
    <ele>600.0</ele>
    <name>E1 · Km 27 · Entrada a Salvatierra</name>
    <desc>La muralla medieval en el horizonte. Entrar por la Puerta de Santa María.</desc>
  </wpt>
  <wpt lat="42.850200" lon="-2.388200">
    <ele>600.0</ele>
    <name>E1 · Km 28 · LLEGADA Salvatierra-Agurain</name>
    <desc>El Gordo · Calle Mayor 69 · Montse: 699 453 986. Explorar casco amurallado a pie.</desc>
  </wpt>
  <wpt lat="42.876000" lon="-2.248000">
    <ele>557.3</ele>
    <name>E2 · Km 15 · Límite Álava/Navarra</name>
    <desc>Mojón de provincia. Foto obligatoria. Sierra de Urbasa a la derecha (~1.000 m). 5 min.</desc>
  </wpt>
  <wpt lat="42.900300" lon="-2.167900">
    <ele>524.4</ele>
    <name>E2 · Km 20 · Alsasua · ALMUERZO</name>
    <desc>Primera gran localidad navarra. Supermercado, farmacia, bares. Almuerzo ideal. 30-40 min.</desc>
  </wpt>
  <wpt lat="42.883300" lon="-2.101400">
    <ele>535.8</ele>
    <name>E2 · Km 27 · Olazagutia</name>
    <desc>Pueblo navarro. Al norte: Sierra de Aralar con santuario San Miguel in Excelsis (s. XII). 5 min.</desc>
  </wpt>
  <wpt lat="42.898700" lon="-2.069400">
    <ele>488.2</ele>
    <name>E2 · Km 34 · LLEGADA Etxarri-Aranatz</name>
    <desc>Hotel Aritzalko · Ctra. Pamplona-Vitoria Km 23 · Tel: 948 46 00 51. Sirve desayunos.</desc>
  </wpt>
  <wpt lat="42.904200" lon="-1.998300">
    <ele>483.1</ele>
    <name>E3 · Km 5 · Arbizu</name>
    <desc>Primer pueblo Vía Verde. Bar y fuente en la plaza. El río Arakil aparece. 5 min.</desc>
  </wpt>
  <wpt lat="42.912500" lon="-1.937200">
    <ele>472.3</ele>
    <name>E3 · Km 10 · Viaducto de Goldaratz</name>
    <desc>Puente de arco de piedra del antiguo ferrocarril sobre el río Araquil. Verlo desde abajo. 10 min.</desc>
  </wpt>
  <wpt lat="42.918000" lon="-1.889200">
    <ele>447.0</ele>
    <name>E3 · Km 14 · Lacunza · Fuente</name>
    <desc>Caserío con fuente junto a la ermita. 5 min.</desc>
  </wpt>
  <wpt lat="42.919500" lon="-1.851400">
    <ele>461.0</ele>
    <name>E3 · Km 18 · Mojón Camino Real</name>
    <desc>Inscripción: "A Pamplona tres leguas". Resto del antiguo camino Pamplona-San Sebastián. 5 min.</desc>
  </wpt>
  <wpt lat="42.917800" lon="-1.828700">
    <ele>465.0</ele>
    <name>E3 · Km 22 · Túneles de Ihabar</name>
    <desc>Primeros túneles cortos de la Vía Verde. Paso calizo de Dos Hermanas junto al río.</desc>
  </wpt>
  <wpt lat="42.912600" lon="-1.806100">
    <ele>502.8</ele>
    <name>E3 · Km 25 · LLEGADA Irurzun</name>
    <desc>Hotel Plazaola *** · C/ Aralar 8 · Tel: 948 50 63 13. Restaurante propio.</desc>
  </wpt>
  <wpt lat="42.953100" lon="-1.851400">
    <ele>520.8</ele>
    <name>E4 · Km 5 · Viaducto de Gulina</name>
    <desc>Arco de piedra ~40 m sobre el barranco. Mirador junto al viaducto. PARADA OBLIGATORIA. 10 min.</desc>
  </wpt>
  <wpt lat="42.974100" lon="-1.866700">
    <ele>524.2</ele>
    <name>E4 · Km 9 · Lekunberri · ÚLTIMO AVITUALLAMIENTO</name>
    <desc>ÚLTIMA OPORTUNIDAD antes del túnel. Supermercado, bares, farmacia. Centro interpretación Plazaola. 20 min.</desc>
  </wpt>
  <wpt lat="42.992200" lon="-1.876800">
    <ele>547.9</ele>
    <name>E4 · Km 12 · Mugiro · Último caserío</name>
    <desc>El camino sube. Silencio, hayedos. Sin bares hasta el km 22.</desc>
  </wpt>
  <wpt lat="43.034200" lon="-1.875100">
    <ele>660.5</ele>
    <name>E4 · Km 17 · ENTRADA Túnel de Huici</name>
    <desc>*** 2.700 m OSCURIDAD · ~12°C · suelo mojado · ENCENDER LINTERNAS *** Tiempo de paso: 15-20 min.</desc>
  </wpt>
  <wpt lat="43.056400" lon="-1.876900">
    <ele>605.1</ele>
    <name>E4 · Km 19,7 · SALIDA Túnel de Huici</name>
    <desc>¡Estáis en Gipuzkoa! El aire huele diferente. FOTO DEL GRUPO en la boca del túnel. 10 min.</desc>
  </wpt>
  <wpt lat="43.092000" lon="-1.895000">
    <ele>515.0</ele>
    <name>E4 · Km 25 · Desvío a Leitza</name>
    <desc>Giráis hacia Leitza: 5 km subida / ~200 m desnivel. La Vía Verde sigue recto (etapa de mañana).</desc>
  </wpt>
  <wpt lat="43.092700" lon="-1.919700">
    <ele>504.2</ele>
    <name>E4 · Km 30 · LLEGADA Leitza</name>
    <desc>Leitzarooms · Tel: 621 245 604. Supermercado en el mismo edificio.</desc>
  </wpt>
  <wpt lat="43.077000" lon="-1.885000">
    <ele>548.7</ele>
    <name>E5 · Km 5 · Vuelta a la Vía Verde</name>
    <desc>Reincorporación al trazado del Plazaola (Gipuzkoa). Río Leizarán a la derecha. 5 min.</desc>
  </wpt>
  <wpt lat="43.104000" lon="-1.908000">
    <ele>527.0</ele>
    <name>E5 · Km 9 · Tramo salvaje del Leizarán</name>
    <desc>Valle estrecho, cascadas, helechos gigantes, bosque cerrado. Sin cobertura móvil. El tramo más bonito.</desc>
  </wpt>
  <wpt lat="43.128000" lon="-1.942000">
    <ele>373.6</ele>
    <name>E5 · Km 13 · Zona tráfico mixto</name>
    <desc>ATENCION: camiones madereros comparten el firme. Mantened la derecha y ceded el paso.</desc>
  </wpt>
  <wpt lat="43.165900" lon="-2.000300">
    <ele>196.8</ele>
    <name>E5 · Km 18 · Berástegi</name>
    <desc>Primer pueblo guipuzcoano. Bar en el cruce. Café. 10 min.</desc>
  </wpt>
  <wpt lat="43.222100" lon="-2.016400">
    <ele>67.6</ele>
    <name>E5 · Km 28 · Andoáin · FIN VÍA VERDE</name>
    <desc>FIN OFICIAL de la Vía Verde del Plazaola. Iglesia barroca San Martín de Tours (1759). Almuerzo. 30-40 min.</desc>
  </wpt>
  <wpt lat="43.267900" lon="-1.977500">
    <ele>8.0</ele>
    <name>E5 · Km 33 · Hernani</name>
    <desc>El carril bici del río Urumea comienza aquí.</desc>
  </wpt>
  <wpt lat="43.290000" lon="-1.970000">
    <ele>7.6</ele>
    <name>E5 · Km 37 · Carril bici río Urumea</name>
    <desc>La entrada más bonita posible a San Sebastián. Seguir el río hasta el centro.</desc>
  </wpt>
  <wpt lat="43.299000" lon="-1.984800">
    <ele>11.1</ele>
    <name>E5 · Km 42 · LLEGADA San Sebastián</name>
    <desc>Ametzagana · Camino de Uba 61 · Tel: 943 45 90 92. Check-in 16:00-21:30. Bicis en recepción. Reservar desayuno.</desc>
  </wpt>
  <trk>
    <name>Etapa 1 · Vitoria → Salvatierra-Agurain (28 km)</name>
