<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="Pedaleando voy, pedaleando vengo 2026"
  xmlns="http://www.topografix.com/GPX/1/1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
  <metadata><name>Día 6 · Leitza → San Sebastián</name><desc>Viaje en bici Julio 2026 · Vía Verde del Plazaola</desc></metadata>
  <wpt lat="43.092700" lon="-1.919700">
    <ele>504.2</ele>
    <name>Km 0 · Partida</name>
    <desc>Leitza. Descenso por carretera de montaña&#10;para retomar la Vía Verde del Plazaola (~5 km de bajada).</desc>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="43.077000" lon="-1.885000">
    <ele>494.8</ele>
    <name>Km 5 · Vuelta a la Vía Verde (Gipuzkoa)</name>
    <desc>Reincorporación al trazado del Plazaola.&#10;Señalización guipuzcoana. El río Leizarán a la derecha.&#10;Parada: 5 min.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="43.104000" lon="-1.908000">
    <ele>494.8</ele>
    <name>Km 9 · Tramo salvaje del Leizarán</name>
    <desc>El valle se estrecha. Paredes de roca, cascadas,&#10;helechos gigantes, bosque cerrado. Sin cobertura móvil.&#10;★ EL TRAMO MÁS BONITO DEL DÍA.</desc>
    <sym>Camera</sym>
  </wpt>
  <wpt lat="43.128000" lon="-1.942000">
    <ele>373.6</ele>
    <name>Km 13 · Zona tráfico mixto ⚠️</name>
    <desc>Algunos km comparten firme con camiones madereros.&#10;Mantened la derecha y cedeed el paso.</desc>
    <sym>Flag, Red</sym>
  </wpt>
  <wpt lat="43.165900" lon="-2.000300">
    <ele>196.8</ele>
    <name>Km 18 · Berástegi</name>
    <desc>Primer pueblo guipuzcoano importante en ruta.&#10;Bar en el cruce. Parada para café si el ritmo lo permite.&#10;Parada: 10 min.</desc>
    <sym>Restaurant</sym>
  </wpt>
  <wpt lat="43.222100" lon="-2.016400">
    <ele>67.6</ele>
    <name>Km 28 · Andoáin · FIN VÍA VERDE</name>
    <desc>FIN OFICIAL de la Vía Verde del Plazaola.&#10;Iglesia barroca San Martín de Tours (1759).&#10;★ ALMUERZO RECOMENDADO antes del tramo urbano.&#10;Parada: 30-40 min.</desc>
    <sym>Restaurant</sym>
  </wpt>
  <wpt lat="43.267900" lon="-1.977500">
    <ele>8.0</ele>
    <name>Km 33 · Hernani</name>
    <desc>Área metropolitana de Donostia.&#10;El carril bici del río Urumea comienza aquí.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="43.290000" lon="-1.970000">
    <ele>7.6</ele>
    <name>Km 37 · Carril bici río Urumea</name>
    <desc>El carril bici sigue el río Urumea&#10;hasta el corazón de San Sebastián.&#10;La entrada más bonita posible a la ciudad.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="43.299000" lon="-1.984800">
    <ele>11.1</ele>
    <name>Km 42 · LLEGADA San Sebastián</name>
    <desc>Ametzagana · Camino de Uba 61&#10;Tel: 943 45 90 92&#10;Check-in: 16:00-21:30 h · Bicis en recepción&#10;★ Reservar desayuno para mañana al hacer check-in.&#10;¡IR DIRECTOS A LA CONCHA!</desc>
    <sym>Lodging</sym>
  </wpt>
  <trk>
    <name>Día 6 · Leitza → San Sebastián</name>
