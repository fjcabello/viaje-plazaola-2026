<?xml version="1.0" encoding="UTF-8"?>
<gpx version="1.1" creator="Pedaleando voy, pedaleando vengo 2026"
  xmlns="http://www.topografix.com/GPX/1/1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd">
  <metadata><name>Día 5 · Irurzun → Leitza</name><desc>Viaje en bici Julio 2026 · Vía Verde del Plazaola</desc></metadata>
  <wpt lat="42.912600" lon="-1.806100">
    <ele>502.8</ele>
    <name>Km 0 · Partida ⚠️ COMPROBAR</name>
    <desc>Irurzun. Antes de salir verificar:&#10;✅ Linterna funcionando&#10;✅ Chubasquero accesible&#10;✅ Agua y bocadillo (sin bares entre km 12 y km 22)</desc>
    <sym>Flag, Green</sym>
  </wpt>
  <wpt lat="42.953100" lon="-1.851400">
    <ele>520.8</ele>
    <name>Km 5 · Viaducto de Gulina</name>
    <desc>Arco de piedra de ~40 m de altura sobre el barranco.&#10;Mirador acondicionado junto al viaducto.&#10;★ PARADA OBLIGATORIA. Parada: 10 min.</desc>
    <sym>Flag, Red</sym>
  </wpt>
  <wpt lat="42.974100" lon="-1.866700">
    <ele>524.2</ele>
    <name>Km 9 · Lekunberri · ÚLTIMO AVITUALLAMIENTO</name>
    <desc>Centro del Valle de Larráun.&#10;Supermercado, farmacia, bares.&#10;★ ÚLTIMA OPORTUNIDAD para abastecer antes del túnel.&#10;Centro interpretación Plazaola en la antigua estación.&#10;Parada: 20 min.</desc>
    <sym>Restaurant</sym>
  </wpt>
  <wpt lat="42.992200" lon="-1.876800">
    <ele>547.9</ele>
    <name>Km 12 · Mugiro · Último caserío</name>
    <desc>Último caserío antes del túnel.&#10;El camino sube. Silencio, hayedos, agua del río.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="43.034200" lon="-1.875100">
    <ele>660.5</ele>
    <name>Km 17 · ENTRADA Túnel de Huici</name>
    <desc>★★★ 2.700 m de OSCURIDAD · ~12°C · suelo mojado&#10;ENCENDER LINTERNAS AHORA&#10;Tiempo de paso en bici: 15-20 minutos (despacio)&#10;Cruza la divisoria mediterránea/cantábrica.&#10;La experiencia más memorable de toda la ruta.</desc>
    <sym>Flag, Red</sym>
  </wpt>
  <wpt lat="43.056400" lon="-1.876900">
    <ele>605.1</ele>
    <name>Km 19,7 · SALIDA Túnel de Huici</name>
    <desc>¡La luz al final del túnel!&#10;Estáis en Gipuzkoa. El aire huele diferente: más atlántico.&#10;★ FOTO DEL GRUPO en la boca del túnel.&#10;Parada: 10 min.</desc>
    <sym>Camera</sym>
  </wpt>
  <wpt lat="43.077000" lon="-1.885000">
    <ele>548.7</ele>
    <name>Km 22 · Inicio descenso Valle Leizarán</name>
    <desc>La Vía Verde baja suavemente.&#10;El río Leizarán aparece y os acompaña.&#10;Biotopo Protegido: nutrias, truchas, milanos reales, buitres leonados.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="43.092000" lon="-1.895000">
    <ele>515.0</ele>
    <name>Km 25 · Desvío a Leitza</name>
    <desc>La Vía Verde continúa hacia Andoáin (mañana).&#10;Giráis por la carretera de montaña hacia Leitza:&#10;~5 km de subida / ~200 m de desnivel.&#10;El esfuerzo final del día.</desc>
    <sym>Flag, Blue</sym>
  </wpt>
  <wpt lat="43.092700" lon="-1.919700">
    <ele>495.6</ele>
    <name>Km 30 · LLEGADA Leitza</name>
    <desc>Leitzarooms · Tel: 621 245 604&#10;info@leizarooms.com&#10;Supermercado en el mismo edificio. Bicis en la habitación.</desc>
    <sym>Lodging</sym>
  </wpt>
  <trk>
    <name>Día 5 · Irurzun → Leitza</name>
